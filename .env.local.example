# =================================================================
# PixelMage BE — Local Testing Environment Variables
# =================================================================
# Copy file này thành .env.local và điền các giá trị THẬT
# File .env.local đã được .gitignore — KHÔNG commit lên git!
#
# Các biến KHÔNG cần giá trị thật (có default trong config-repo):
#   - DB_HOST, DB_USER, DB_PASS → dùng Docker SQL Server
#   - REDIS_HOST, REDIS_PASSWORD → dùng Docker Redis
#   - RABBITMQ_HOST, RABBITMQ_USER, RABBITMQ_PASS → dùng Docker RabbitMQ
#
# Chỉ cần giá trị THẬT cho các external services bên dưới:
# =================================================================

# ─── 1. JWT SECRET ─────────────────────────────────────────────
# Có thể tự generate: openssl rand -base64 32
# Hoặc dùng default trong config-repo/application.yml để test local
# Default: cGl4ZWxtYWdlLXN1cGVyLXNlY3JldC1rZXktbXVzdC1iZS1hdC1sZWFzdC0yNTYtYml0cw==
JWT_SECRET=cGl4ZWxtYWdlLXN1cGVyLXNlY3JldC1rZXktbXVzdC1iZS1hdC1sZWFzdC0yNTYtYml0cw==

# ─── 2. GOOGLE OAUTH2 ──────────────────────────────────────────
# Lấy từ: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Cần tạo project + enable Google+ API + set Authorized redirect URIs:
#   http://localhost:8080/api/auth/google/callback
#   http://localhost:8101/api/auth/google/callback (direct)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── 3. VNPAY SANDBOX ──────────────────────────────────────────
# Đăng ký sandbox tại: https://sandbox.vnpayment.vn/devreg/
# Sau khi đăng ký nhận được TMN Code và Hash Secret
# Sandbox không tính phí, dùng test card: 9704198526191432198 (NCB)
VNPAY_TMN_CODE=U40MCGMP
VNPAY_HASH_SECRET=0D4ONYKD46KEGRHNDD07L0LO6F5Y1TJ4
VNPAY_RETURN_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ─── 4. OPENAI (TÙY CHỌN) ─────────────────────────────────────
# Nếu để trống → reading-service dùng MOCK mode (không gọi thật)
# Chỉ cần điền nếu muốn test AI interpretation thật
# Lấy từ: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── 5. READING DAILY LIMIT ────────────────────────────────────
# Số lần đọc bài tối đa 1 ngày (local test: set cao để test dễ hơn)
READING_DAILY_LIMIT=99

# =================================================================
# CÁC BIẾN SAU ĐÃ CÓ DEFAULT — CHỈ CẦN GHI ĐÈ NẾU MUỐN
# =================================================================

# Docker SQL Server (default từ docker-compose.yml)
# DB_HOST=localhost
# DB_USER=sa
# DB_PASS=PixelMage@2024!

# Docker Redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=pixelmage_redis

# Docker RabbitMQ
# RABBITMQ_HOST=localhost
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
